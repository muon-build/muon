W = 79 * 10000
H = 32 * 10000
MAX = 200
fractal_r = 28000 * 10000 / W
fractal_i = 28000 * 10000 / H
c_r = -7000
c_i = 2700
h = H * 3 / 4
y = 0
lines = []
foreach _ : range(4294967295)
    if not (y < h)
        break
    endif
    line = ''
    x = 0
    foreach _ : range(4294967295)
        if not (x < W)
            break
        endif
        z_r = x * fractal_r / 10000 - 14000
        z_i = y * fractal_i / 10000 - 10000
        n = 0
        foreach _ : range(4294967295)
            if not (
                ((z_r * z_r) / 10000 + (z_i * z_i) / 10000) < 4 * 10000
                and n < MAX
            )
                break
            endif
            f_r = z_r * z_r / 10000 - z_i * z_i / 10000 + c_r
            f_i = 2 * z_r * z_i / 10000 + c_i
            z_r = f_r
            z_i = f_i
            n += 1
        endforeach
        if n == MAX
            line += '@'
        elif n > MAX * 40 / 100
            line += '#'
        elif n > MAX * 20 / 100
            line += '='
        elif n > MAX * 10 / 100
            line += '+'
        elif n > MAX * 5 / 100
            line += ':'
        elif n > MAX / 100
            line += ' '
        else
            line += '.'
        endif
        x += 10000
    endforeach
    print(line + '\n')
    lines += line
    y += 10000
endforeach

joined = '\n'.join(lines)

expected = '\n'.join(
    [
        '...............................................................................',
        '..................................                    .........................',
        '.............................            ##                 ...................',
        '.........................               :#+@#                    ..............',
        '.....................                #@#@@@@#=                         ........',
        '..................                @@@#=@@###=@:::+@#@#                      ...',
        '..............                   @@@+#=@@#=#@#+##@##@::#:       @=#@#+         ',
        '..........                        @=::::+@@@@=@#@==###=@+@@    ::##=@::@@      ',
        '......         @+@     @:          ::::#@=##@=@@##@###@@#####:::@@@@@#=@#:  +  ',
        '...           @#@@#@::#@@::=@:::#:::#+:+#@=@#=#@#@@@@@@@@######@@+##@@@@@#@=##=',
        '             =+##=@#+#@@=##==@@##++@#@@@++#=@@#@@#@@@@@@@@@@@#=####@@####@@+#+=',
        '             ::@#@@=@@#@#@#####@@##@@@@@#@#==#@@@#@@@@@@#@@@@##++@::##+@@:@@@  ',
        '   :#=###@##:=#++#@@####@@@@@@#@@@#==@######@@@#@##@######@@=@##+::            ',
        '+##@##@@#@@#=@@@=##@@#@@@@@@@@#@@#@@##++@@@@#+:@@#@+@##=##++#@@@###            ',
        ' @+=@+=@@@@###+=@@@#####@@@@##@#@@=@#@#++::#::::: :##@:=##+::+@@#:           ..',
        '      :===@=@#@#:::@==@@#@@@@@@##@==@#@#@::::                 #:@        ......',
        '         #:@@#@:@    :@+@@##==@#=+#=#@@@+:::@==                      ..........',
        '.         #@=#:#        #=:=#@=#:+@#@@=#@@#@##@                  ..............',
        '.....                     #@@@#+::@@###@@+@@@#                .................',
        '..........                        :=#@@@#:+               .....................',
        '................                   @+@@:               ........................',
        '.....................                @+            ............................',
        '...........................                  ..................................',
        '...............................................................................',
    ],
)

assert(joined == expected)
