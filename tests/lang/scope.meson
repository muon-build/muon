# Test that flags declared before function is used as an upvalue
(
    func()
        flags = []

        func bar() -> list[str]
            flags = ['a']

            flags += ['b']

            return flags
        endfunc

        flags = ['c']
        assert(bar() == ['a', 'b'])
        assert(flags == ['a', 'b'])
    endfunc
)()

# Test that flags declared after function is not used as an upvalue
(
    func()
        func bar() -> list[str]
            flags = ['a']

            flags += ['b']

            return flags
        endfunc

        flags = ['c']
        assert(bar() == ['a', 'b'])
        assert(flags == ['c'])
    endfunc
)()

# Test flags declared before function, but assignment forced
(
    func()
        flags = []

        func bar() -> list[str]
            flags := ['a']

            flags += ['b']

            return flags
        endfunc

        flags = ['c']
        assert(bar() == ['a', 'b'])
        assert(flags == ['c'])
    endfunc
)()
