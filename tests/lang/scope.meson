tests = []

func add_test(desc str, fn function)
    tests += {'desc': desc, 'fn': fn}
endfunc

add_test(
    'Test that flags declared before function is used as an upvalue',
    func()
        flags = []

        func bar() -> list[str]
            flags = ['a']

            flags += ['b']

            return flags
        endfunc

        flags = ['c']
        assert(bar() == ['a', 'b'])
        assert(flags == ['a', 'b'])
    endfunc,
)

add_test(
    'Test that flags declared after function is not used as an upvalue',
    func()
        func bar() -> list[str]
            flags = ['a']

            flags += ['b']

            return flags
        endfunc

        flags = ['c']
        assert(bar() == ['a', 'b'])
        assert(flags == ['c'])
    endfunc,
)

add_test(
    'Test flags declared before function, but assignment forced',
    func()
        flags = []

        func bar() -> list[str]
            flags := ['a']

            flags += ['b']

            return flags
        endfunc

        flags = ['c']
        assert(bar() == ['a', 'b'])
        assert(flags == ['c'])
    endfunc,
)

add_test(
    'Test recursive calls and equivalence of = and +=',
    func()
        i = 0
        j = 0
        n = 0
        s = ''
        t = ''

        func fib(n int) -> int
            i = i + 1
            j += 1

            s = s + '_' + n.to_string()
            t += '_' + n.to_string()

            return n <= 1 ? n : fib(n - 1) + fib(n - 2)
        endfunc

        assert(fib(5) == 5)
        assert(i == j and i == 15)
        assert(s == t and s == '_5_4_3_2_1_0_1_2_1_0_3_2_1_0_1')
        assert(n == 0)
    endfunc,
)

add_test(
    '`func foo` does not force a local declaration, so it may bind with an upvalue',
    func()
        foo = 'a string'

        func bar()
            func foo()
                message('hello from foo')
            endfunc
        endfunc

        assert(typeof(foo) == 'str')
        message('foo is a ' + typeof(foo))
        bar()
        assert(typeof(foo) == 'function')
        message('foo is now a ' + typeof(foo))
        foo()
    endfunc,
)

add_test(
    'force-declaration in the middle of a function body only affects later code',
    func()
        foo = 'set at outer scope'

        func bar()
            message(foo)
            foo = 'set at inner scope' # This mutates the foo upvalue declared above
            message(foo)
            foo := 'local to bar' # This declares a new local variable that shadows foo
            foo = 'still local to bar' # This mutates the foo local
            message(foo)
            assert(foo == 'still local to bar')
        endfunc

        bar()
        message(foo)
        assert(foo == 'set at inner scope')
    endfunc,
)

add_test(
    'a += b and a = a + b are mutations for container types',
    func()
        a = [1]
        b = [2]

        func foo(a list[int], b list[int])
            a = a + a
            b += b
        endfunc

        foo(a, b)

        assert(a == [1], '`a` should not be mutated, = was used')
        assert(b == [2, 2], '`b` should be mutated, += was used')
    endfunc,
)

add_test(
    'foreach does not create scopes',
    func()
        k = 'not set'

        func foo() -> int
            foreach k, v : {'a': 1}
                c = 1
            endforeach
            assert(c == 1)
            return v
        endfunc

        assert(foo() == 1, 'v should be equal to the last iteration')
        assert(k == 'a', 'k should have been reused as an upvalue')
    endfunc,
)

add_test(
    'simulated object with private member',
    func()
        counter = (
            func() -> dict[function]
                i = 0

                return {
                    'is': func(val int) -> bool
                        return i == val
                    endfunc,
                    'reset': func(val int: 0)
                        i = val
                    endfunc,
                    'inc': func()
                        i += 1
                    endfunc,
                }
            endfunc
        )()
        assert(counter.is(0))
        counter.inc()
        counter.inc()
        assert(counter.is(2))
        counter.reset()
        assert(counter.is(0))
        counter.reset(val: 3)
        assert(counter.is(3))
    endfunc,
)

foreach t : tests
    print(f'---- @0@ ----\n'.format(t.desc))
    t.fn()
endforeach
